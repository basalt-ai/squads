{
  "name": "meta-ads-squad",
  "version": "0.1.0",
  "description": "Single-agent Meta Ads squad: daily diagnostic + action sweep, daily digest, weekly review. Holds spend flat autonomously; escalates only budget increases.",
  "author": "pancake-official",
  "license": "MIT",
  "skills": [
    "skills/methodology/pancake-meta-ads-01-account-foundations.md",
    "skills/methodology/pancake-meta-ads-02-campaign-architecture.md",
    "skills/methodology/pancake-meta-ads-03-budget-and-bid-controls.md",
    "skills/methodology/pancake-meta-ads-04-ad-asset-handbook.md",
    "skills/methodology/pancake-meta-ads-05-people-targeting.md",
    "skills/methodology/pancake-meta-ads-06-placement-rotation.md",
    "skills/methodology/pancake-meta-ads-07-advantage-plus-and-catalog.md",
    "skills/methodology/pancake-meta-ads-08-attribution-and-tracking.md",
    "skills/methodology/pancake-meta-ads-09-policy-and-privacy.md",
    "skills/methodology/pancake-meta-ads-10-root-cause-analysis.md",
    "skills/operations/pancake-meta-ads-11-guardian-rules.md",
    "skills/operations/pancake-meta-ads-12-review-cadence.md",
    "skills/operations/pancake-meta-ads-13-operational-routines.md"
  ],
  "agents": ["meta-ads-agent"],
  "required_vault_secrets": [
    {
      "key": "team.meta_api_token",
      "label": "Meta Marketing API System User access token (long-lived, never expires)",
      "type": "token"
    },
    {
      "key": "team.meta_ad_account_id",
      "label": "Meta ad account ID (format act_XXXXX)",
      "type": "string"
    },
    {
      "key": "team.meta_pixel_id",
      "label": "Meta Pixel ID (for measurement and EMQ tracking)",
      "type": "string"
    },
    {
      "key": "team.meta_capi_dataset_id",
      "label": "CAPI Gateway dataset ID (optional — leave blank if not using CAPI Gateway)",
      "type": "string"
    },
    {
      "key": "team.account_currency",
      "label": "Account currency (ISO 4217, e.g. USD, GBP, EUR)",
      "type": "string"
    },
    {
      "key": "team.account_timezone",
      "label": "Account timezone (IANA, e.g. America/New_York)",
      "type": "string"
    },
    {
      "key": "team.account_business_model",
      "label": "Business model: ecommerce | lead_gen | saas | app | local | dual",
      "type": "string"
    },
    {
      "key": "team.account_maturity_level",
      "label": "Account maturity: nascent | developing | established | advanced",
      "type": "string"
    },
    {
      "key": "team.primary_kpi",
      "label": "Primary KPI: cpa | roas | cpl | cpv | cpm",
      "type": "string"
    },
    {
      "key": "team.kpi_target",
      "label": "Numeric target for the primary KPI (e.g. 45.00 for $45 CPA, 4.0 for 4x ROAS)",
      "type": "string"
    },
    {
      "key": "team.flag_thresholds",
      "label": "Critical/warning thresholds as JSON (overrides skill-01 defaults — leave blank for defaults)",
      "type": "string"
    },
    {
      "key": "team.naming_conventions",
      "label": "Campaign/ad-set/ad name templates as JSON (enables automated segmentation parsing — leave blank for defaults)",
      "type": "string"
    }
  ],
  "required_tool_permissions": [
    "mcp-installer",
    "vault"
  ],
  "min_pancake_version": "1.0.0"
}
